# AWS Bedrock API key in ABSK format — the sole credential used to authenticate with Bedrock
AWS_BEARER_TOKEN_BEDROCK=your-absk-api-key-here

# AWS region where the Bedrock endpoint is located (defaults to us-east-1 if not set)
AWS_REGION=us-east-1

# Bedrock model ID to invoke (defaults to anthropic.claude-3-5-sonnet-20241022-v2:0 if not set)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Set to "true" to enable HTTP Basic Authentication on all routes (useful when exposing publicly via tunnel)
AUTH_ENABLED=false

# Username for HTTP Basic Auth — required when AUTH_ENABLED=true
AUTH_USERNAME=your-username-here

# Password for HTTP Basic Auth — required when AUTH_ENABLED=true
AUTH_PASSWORD=your-password-here
